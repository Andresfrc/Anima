# ──────────────────────────────────────────────────────────────────────────
# Variables de entorno de AnimaApp (Expo)
# Copia este archivo a `.env` y rellena los valores reales.
# En Expo SDK 49+, las variables con prefijo EXPO_PUBLIC_ se inyectan en el
# bundle del cliente en tiempo de build. NO pongas secretos de servidor aquí.
# ──────────────────────────────────────────────────────────────────────────

# Supabase (la anon key es pública por diseño; la seguridad real está en RLS)
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Backend del chatbot (Lumi)
EXPO_PUBLIC_CHAT_API_URL=https://chatbot-lumi.onrender.com

# Error tracking (opcional — si está vacío, no se reporta nada)
EXPO_PUBLIC_SENTRY_DSN=
